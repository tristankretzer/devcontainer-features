{
  "name": "Podman in Podman",
  "id": "podman-in-podman",
  "version": "0.3.1",
  "description": "A feature to install Podman inside a Podman container.",
  "options": {
    "installPodmanDocker": {
      "type": "boolean",
      "description": "Install package podman-docker",
      "default": false
    }
  },
  "securityOpt": [
    "label=disable"
  ],
  "containerEnv": {
    "_CONTAINERS_USERNS_CONFIGURED": ""
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}
